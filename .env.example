# Amar Honda Care — Environment Variables
# Copy this file to .env and fill in your values

SECRET_KEY=django-insecure-amar-honda-care-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (for production switch to PostgreSQL)
# DATABASE_URL=postgres://user:password@localhost:5432/amar_honda_care

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@amarhondacare.com
